# Supabase
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Clé « anon public » (JWT eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...), section « Project API keys » du dashboard.
# Ne pas mettre la clé sb_publishable_… ici : PostgREST / supabase-js attendent le JWT anon (sinon 401 sur les requêtes).
VITE_SUPABASE_ANON_KEY=

# PessoBot (n8n webhook)
VITE_PESSOBOT_WEBHOOK_URL=
# Signature partagée front ↔ n8n (même valeur des deux côtés). À régénérer avant la mise en prod.
# Exemple : openssl rand -hex 24
VITE_PESSOBOT_SIGNATURE=

# Démo espace client (/demo-espace) — identifiants d’un compte de test Supabase (non secrets en dev ; prod : utiliser un compte dédié).
VITE_DEMO_EMAIL=demo@pessora.mq
VITE_DEMO_PASSWORD=demo123

# ─── Supabase Edge Functions (secrets — Supabase Dashboard > Edge Functions > Secrets) ───
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ORA_PLUS_PRICE_ID=price_...

# Resend (emails transactionnels)
RESEND_API_KEY=re_...

# Config site (CORS, emails)
ALLOWED_ORIGIN=https://www.pessora.mq
SITE_URL=https://www.pessora.mq
CONTACT_EMAIL=contact@pessora.mq
ADMIN_EMAIL=pessora.mq@gmail.com

# Óra+ pricing (en centimes, ex: 2490 = 24,90 €)
ORA_PLUS_PRICE_AMOUNT=2490
