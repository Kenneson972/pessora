## 11. Idempotence — table `email_log`

Les webhooks Stripe sont livrés **plusieurs fois**. Sans idempotence, un user
reçoit 3 fois le même reçu.

```sql
create table public.email_log (
  id           uuid primary key default gen_random_uuid(),
  event_id     text not null,          -- stripe_event_id, booking_id, etc.
  template     text not null,          -- 'order_paid', etc.
  recipient    text not null,          -- email destinataire
  status       text not null,          -- 'sent' | 'failed'
  provider_id  text,                   -- Resend message id
  error        text,
  sent_at      timestamptz not null default now(),
  unique (event_id, template, recipient)
);
```

```ts
// lib/email/log.ts
import 'server-only'
import { supabaseAdmin } from '@/lib/supabase/admin'

export async function wasSent(args: { eventId: string; template: string; to: string }) {
  const db = supabaseAdmin()
  const { data } = await db
    .from('email_log')
    .select('id')
    .eq('event_id', args.eventId)
    .eq('template', args.template)
    .eq('recipient', args.to)
    .eq('status', 'sent')
    .maybeSingle()
  return !!data
}

export async function logEmail(args: {
  eventId: string
  template: string
  to: string
  status: 'sent' | 'failed'
  providerId?: string
  error?: string
}) {
  const db = supabaseAdmin()
  await db.from('email_log').insert({
    event_id: args.eventId,
    template: args.template,
    recipient: args.to,
    status: args.status,
    provider_id: args.providerId,
    error: args.error,
  })
}
```

La contrainte `unique (event_id, template, recipient)` est la ligne de
défense ultime : même si deux workers envoient simultanément, l'INSERT du
second fera un `duplicate key` — on catch et skip.

