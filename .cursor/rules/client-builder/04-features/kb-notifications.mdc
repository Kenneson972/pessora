## 10. Helper `sendEmail()` — typé, serveur uniquement

```ts
// lib/email/send.ts
import 'server-only'
import { Resend } from 'resend'
import { render } from '@react-email/components'
import { OrderPaidEmail } from './templates/OrderPaid'
import { OrderShippedEmail } from './templates/OrderShipped'
import { BookingCreatedEmail } from './templates/BookingCreated'
import { logEmail, wasSent } from './log'

const resend = new Resend(process.env.RESEND_API_KEY!)

type EmailPayload =
  | { template: 'order_paid';      data: { customerName: string; orderId: string; amount: number; orderUrl: string } }
  | { template: 'order_shipped';   data: { customerName: string; orderId: string; trackingUrl: string } }
  | { template: 'booking_created'; data: { customerName: string; bookingId: string; checkIn: string; checkOut: string } }

interface SendArgs {
  to: string
  subject: string
  eventId: string            // ID unique (stripe_event_id, booking_id, etc.)
  payload: EmailPayload
}

export async function sendEmail({ to, subject, eventId, payload }: SendArgs) {
  // Idempotence : si déjà envoyé pour ce (eventId, template, to), skip
  if (await wasSent({ eventId, template: payload.template, to })) {
    console.log('[email] skipped (already sent)', { eventId, template: payload.template })
    return { skipped: true }
  }

  const html = render(renderTemplate(payload))

  const { data, error } = await resend.emails.send({
    from: process.env.EMAIL_FROM!,
    replyTo: process.env.EMAIL_REPLY_TO,
    to,
    subject,
    html,
  })

  if (error) {
    await logEmail({ eventId, template: payload.template, to, status: 'failed', error: error.message })
    throw error
  }

  await logEmail({ eventId, template: payload.template, to, status: 'sent', providerId: data?.id })
  return { skipped: false, id: data?.id }
}

function renderTemplate(p: EmailPayload) {
  switch (p.template) {
    case 'order_paid':      return OrderPaidEmail(p.data)
    case 'order_shipped':   return OrderShippedEmail(p.data)
    case 'booking_created': return BookingCreatedEmail(p.data)
  }
}
```

`import 'server-only'` garantit qu'un `sendEmail()` appelé depuis un client
component jette à la compilation. La clé Resend n'atteint jamais le bundle
navigateur.

