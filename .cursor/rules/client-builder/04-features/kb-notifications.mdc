## 12. Event → Notif + Email combinés (Server Action)

Pattern canonique : 1 event métier → 1 fonction qui fait les deux.

```ts
// app/(api)/stripe/webhook/route.ts (extrait)
import { createNotification } from '@/lib/notifications/create'
import { sendEmail } from '@/lib/email/send'

async function handleOrderPaid(event: Stripe.Event) {
  const session = event.data.object as Stripe.Checkout.Session
  const userId = session.metadata?.user_id
  const orderId = session.metadata?.order_id
  const email = session.customer_details?.email
  if (!userId || !orderId || !email) return

  // 1. Notif in-app (RLS bypass via admin)
  await createNotification({
    user_id: userId,
    type: 'order_paid',
    title: 'Commande confirmée',
    body: `Votre commande #${orderId} a été payée.`,
    link: `/dashboard/orders/${orderId}`,
    metadata: { order_id: orderId, amount: session.amount_total },
  })

  // 2. Email transactionnel (idempotent via event.id)
  await sendEmail({
    to: email,
    subject: `Commande #${orderId} confirmée`,
    eventId: event.id,              // Stripe garantit l'unicité
    payload: {
      template: 'order_paid',
      data: {
        customerName: session.customer_details?.name ?? 'Client',
        orderId,
        amount: (session.amount_total ?? 0) / 100,
        orderUrl: `${process.env.NEXT_PUBLIC_SITE_URL}/dashboard/orders/${orderId}`,
      },
    },
  })
}
```

Le `eventId` utilisé pour l'idempotence de l'email est le même que celui
utilisé pour l'idempotence du webhook (cf `kb-api-routes`). Cohérence totale.

