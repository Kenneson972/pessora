## 4. Realtime Bell — `components/notifications/NotificationBell.tsx`

Client component. Subscribe à `postgres_changes` filtré par `user_id` (jamais
lire les notifs d'un autre user — la RLS empêche, mais on filtre côté client
pour économiser des events).

```tsx
'use client'

import { useCallback, useEffect, useRef, useState } from 'react'
import { useRouter } from 'next/navigation'
import { Bell } from 'lucide-react'
import { createClient } from '@/lib/supabase/client'
import type { Database } from '@/types/supabase'

type Notification = Database['public']['Tables']['notifications']['Row']

interface Props { userId: string }

export function NotificationBell({ userId }: Props) {
  const router = useRouter()
  const supabase = createClient()
  const [items, setItems] = useState<Notification[]>([])
  const [open, setOpen] = useState(false)
  const [animating, setAnimating] = useState(false)
  const ref = useRef<HTMLDivElement>(null)

  const unread = items.filter((n) => !n.read_at).length

  // Fetch initial
  const fetchNotifs = useCallback(async () => {
    const { data } = await supabase
      .from('notifications')
      .select('*')
      .order('created_at', { ascending: false })
      .limit(20)
    if (data) setItems(data)
  }, [supabase])

  useEffect(() => { fetchNotifs() }, [fetchNotifs])

  // Realtime subscription — filtré par user_id
  useEffect(() => {
    const channel = supabase
      .channel(`notifications:${userId}`)
      .on(
        'postgres_changes',
        {
          event: 'INSERT',
          schema: 'public',
          table: 'notifications',
          filter: `user_id=eq.${userId}`,
        },
        (payload) => {
          const fresh = payload.new as Notification
          setItems((prev) => [fresh, ...prev].slice(0, 20))
          setAnimating(true)
          setTimeout(() => setAnimating(false), 800)
        }
      )
      .on(
        'postgres_changes',
        {
          event: 'UPDATE',
          schema: 'public',
          table: 'notifications',
          filter: `user_id=eq.${userId}`,
        },
        (payload) => {
          const updated = payload.new as Notification
          setItems((prev) => prev.map((n) => (n.id === updated.id ? updated : n)))
        }
      )
      .subscribe()

    return () => { supabase.removeChannel(channel) }
  }, [supabase, userId])

  return (
    <div ref={ref} className="relative">
      <button
        onClick={() => setOpen((v) => !v)}
        aria-label={`Notifications${unread ? ` (${unread} non lues)` : ''}`}
        className={animating ? 'animate-[wiggle_0.5s]' : ''}
      >
        <Bell size={18} />
        {unread > 0 && (
          <span className="absolute -top-1 -right-1 rounded-full bg-primary text-[10px] px-1">
            {unread > 9 ? '9+' : unread}
          </span>
        )}
      </button>
      {open && <NotificationList items={items} onClose={() => setOpen(false)} />}
    </div>
  )
}
```

Référence projet : `components/dashboard/NotificationBell.tsx` (Diamant Noir)
pour un exemple complet avec dropdown stylé, icônes par type, et footer
« Tout marquer comme lu ».

