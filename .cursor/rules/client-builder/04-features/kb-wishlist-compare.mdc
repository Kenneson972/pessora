## 10. Server Actions avec Zod

Alternative server-side aux mutations client direct. Utile quand :

- On veut une validation stricte + audit
- On veut que le cache Next.js se revalide (`revalidatePath('/favoris')`)

```ts
// app/actions/wishlist.ts
"use server";
import { z } from "zod";
import { createClient } from "@/lib/supabase-server";
import { revalidatePath } from "next/cache";

const ToggleSchema = z.object({
  itemId: z.string().uuid(),
  itemType: z.enum(["villa", "product", "service"]),
});

export async function toggleWishlist(input: z.infer<typeof ToggleSchema>) {
  const { itemId, itemType } = ToggleSchema.parse(input);
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) throw new Error("Unauthorized");

  const { data: existing } = await supabase
    .from("wishlist_items")
    .select("id")
    .eq("user_id", user.id)
    .eq("item_id", itemId)
    .eq("item_type", itemType)
    .maybeSingle();

  if (existing) {
    await supabase.from("wishlist_items").delete().eq("id", existing.id);
  } else {
    await supabase.from("wishlist_items").insert({
      user_id: user.id, item_id: itemId, item_type: itemType,
    });
  }
  revalidatePath("/favoris");
}

export async function clearWishlist() {
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) throw new Error("Unauthorized");
  await supabase.from("wishlist_items").delete().eq("user_id", user.id);
  revalidatePath("/favoris");
}

const AddCompareSchema = z.object({
  itemId: z.string().uuid(),
  itemType: z.enum(["villa", "product", "service"]),
});

export async function addToCompare(input: z.infer<typeof AddCompareSchema>) {
  const { itemId, itemType } = AddCompareSchema.parse(input);
  const supabase = await createClient();
  const { data: { user } } = await supabase.auth.getUser();
  if (!user) throw new Error("Unauthorized");

  const { count } = await supabase
    .from("compare_items")
    .select("*", { count: "exact", head: true })
    .eq("user_id", user.id);

  if ((count ?? 0) >= 4) {
    throw new Error("Maximum 4 items à comparer");
  }

  await supabase.from("compare_items").insert({
    user_id: user.id, item_id: itemId, item_type: itemType,
  });
  revalidatePath("/comparer");
}
```

**Choix entre store direct et server action** : pour le toggle ultra-rapide (cœur sur une card), le store client suffit — mutation optimiste, sync DB en background. Pour les actions critiques ou paginées, server action.

