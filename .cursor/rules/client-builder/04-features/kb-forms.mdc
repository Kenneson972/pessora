## 4. Formulaire client (react-hook-form + zodResolver)

```tsx
// components/forms/ContactForm.tsx
"use client";

import { useEffect, useState } from "react";
import { useForm } from "react-hook-form";
import { zodResolver } from "@hookform/resolvers/zod";
import { contactSchema, type ContactInput } from "@/lib/validations/contact";
import { submitContact } from "@/app/contact/actions";
import { useToast } from "@/components/ui/use-toast";

export function ContactForm() {
  const { toast } = useToast();
  const [submitted, setSubmitted] = useState(false);

  const form = useForm<ContactInput>({
    resolver: zodResolver(contactSchema),
    defaultValues: {
      name: "",
      email: "",
      phone: "",
      subject: "info",
      message: "",
      consent: false as unknown as true, // typage Zod literal(true)
      website: "",
    },
    mode: "onBlur",
  });

  // UTM tracking au mount
  useEffect(() => {
    const params = new URLSearchParams(window.location.search);
    form.setValue("utm_source", params.get("utm_source") ?? undefined);
    form.setValue("utm_medium", params.get("utm_medium") ?? undefined);
    form.setValue("utm_campaign", params.get("utm_campaign") ?? undefined);
    form.setValue("utm_term", params.get("utm_term") ?? undefined);
    form.setValue("utm_content", params.get("utm_content") ?? undefined);
    form.setValue("referrer", document.referrer || undefined);
  }, [form]);

  const onSubmit = form.handleSubmit(async (values) => {
    const res = await submitContact(values);

    if (!res.success) {
      // Erreurs par champ -> setError sur chaque champ
      if (res.fieldErrors) {
        for (const [field, messages] of Object.entries(res.fieldErrors)) {
          form.setError(field as keyof ContactInput, {
            type: "server",
            message: messages?.[0],
          });
        }
      }
      toast({ title: "Erreur", description: res.error, variant: "destructive" });
      return;
    }

    setSubmitted(true);
    form.reset();
    toast({ title: "Message envoyé", description: "Nous vous recontactons sous 24h." });
  });

  if (submitted) {
    return (
      <div role="status" aria-live="polite" className="rounded-xl bg-emerald-50 p-6 text-emerald-900">
        <h3 className="font-semibold">Merci !</h3>
        <p>Votre message a bien été envoyé. Nous revenons vers vous rapidement.</p>
        <button
          type="button"
          onClick={() => setSubmitted(false)}
          className="mt-4 text-sm underline"
        >
          Envoyer un autre message
        </button>
      </div>
    );
  }

  const { errors, isSubmitting } = form.formState;

  return (
    <form onSubmit={onSubmit} noValidate className="space-y-5">
      {/* Honeypot - caché à l'humain, visible au bot */}
      <div aria-hidden="true" className="absolute left-[-9999px]">
        <label htmlFor="website">Ne pas remplir</label>
        <input
          type="text"
          id="website"
          tabIndex={-1}
          autoComplete="off"
          {...form.register("website")}
        />
      </div>

      <div>
        <label htmlFor="name" className="block text-sm font-medium">Nom *</label>
        <input
          id="name"
          type="text"
          autoComplete="name"
          aria-invalid={!!errors.name}
          aria-describedby={errors.name ? "name-error" : undefined}
          className="mt-1 w-full rounded-md border px-3 py-2"
          {...form.register("name")}
        />
        {errors.name && (
          <p id="name-error" role="alert" className="mt-1 text-sm text-red-600">
            {errors.name.message}
          </p>
        )}
      </div>

      <div>
        <label htmlFor="email" className="block text-sm font-medium">Email *</label>
        <input
          id="email"
          type="email"
          autoComplete="email"
          aria-invalid={!!errors.email}
          aria-describedby={errors.email ? "email-error" : undefined}
          className="mt-1 w-full rounded-md border px-3 py-2"
          {...form.register("email")}
        />
        {errors.email && (
          <p id="email-error" role="alert" className="mt-1 text-sm text-red-600">
            {errors.email.message}
          </p>
        )}
      </div>

      <div>
        <label htmlFor="message" className="block text-sm font-medium">Message *</label>
        <textarea
          id="message"
          rows={5}
          aria-invalid={!!errors.message}
          aria-describedby={errors.message ? "message-error" : undefined}
          className="mt-1 w-full rounded-md border px-3 py-2"
          {...form.register("message")}
        />
        {errors.message && (
          <p id="message-error" role="alert" className="mt-1 text-sm text-red-600">
            {errors.message.message}
          </p>
        )}
      </div>

      <div className="flex items-start gap-2">
        <input
          id="consent"
          type="checkbox"
          aria-invalid={!!errors.consent}
          className="mt-1"
          {...form.register("consent")}
        />
        <label htmlFor="consent" className="text-sm">
          J'accepte la <a href="/confidentialite" className="underline">politique de confidentialité</a> *
        </label>
      </div>
      {errors.consent && (
        <p role="alert" className="text-sm text-red-600">{errors.consent.message}</p>
      )}

      <button
        type="submit"
        disabled={isSubmitting}
        className="rounded-md bg-primary px-5 py-2.5 text-white disabled:opacity-50"
      >
        {isSubmitting ? "Envoi..." : "Envoyer"}
      </button>
    </form>
  );
}
```

