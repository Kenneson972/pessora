## 3. Server Action pattern

```ts
// app/contact/actions.ts
"use server";

import { revalidatePath } from "next/cache";
import { headers } from "next/headers";
import { contactSchema } from "@/lib/validations/contact";
import { rateLimit } from "@/lib/rate-limit";
import { createClient } from "@/lib/supabase/server";
import { sendContactEmail } from "@/lib/email";

type ActionResult =
  | { success: true }
  | { success: false; error: string; fieldErrors?: Record<string, string[]> };

export async function submitContact(input: unknown): Promise<ActionResult> {
  // 1. Rate limit (IP) - voir kb-api-routes
  const ip = (await headers()).get("x-forwarded-for") ?? "unknown";
  const { allowed } = await rateLimit(`contact:${ip}`, { max: 5, window: 60 });
  if (!allowed) {
    return { success: false, error: "Trop de requêtes, réessayez dans une minute." };
  }

  // 2. Validation Zod serveur (source de vérité)
  const parsed = contactSchema.safeParse(input);
  if (!parsed.success) {
    return {
      success: false,
      error: "Formulaire invalide",
      fieldErrors: parsed.error.flatten().fieldErrors,
    };
  }

  // 3. Honeypot - si rempli, succès silencieux (ne pas alerter le bot)
  if (parsed.data.website && parsed.data.website.length > 0) {
    return { success: true };
  }

  // 4. Business logic
  try {
    const supabase = await createClient();
    const { error: dbError } = await supabase.from("leads").insert({
      name: parsed.data.name,
      email: parsed.data.email,
      phone: parsed.data.phone ?? null,
      subject: parsed.data.subject,
      message: parsed.data.message,
      utm_source: parsed.data.utm_source ?? null,
      utm_medium: parsed.data.utm_medium ?? null,
      utm_campaign: parsed.data.utm_campaign ?? null,
      utm_term: parsed.data.utm_term ?? null,
      utm_content: parsed.data.utm_content ?? null,
      referrer: parsed.data.referrer ?? null,
      ip,
    });
    if (dbError) throw dbError;

    await sendContactEmail(parsed.data);

    // 5. Revalidation si la mutation affecte une page (admin dashboard, compteurs...)
    revalidatePath("/admin/leads");

    return { success: true };
  } catch (e) {
    console.error("[submitContact]", e);
    return { success: false, error: "Erreur serveur, réessayez plus tard." };
  }
}
```

Points clés :
- `"use server"` en haut du fichier.
- Return type discriminé (`success: true | false`) pour TypeScript côté client.
- Rate limit AVANT parsing (pas de work inutile).
- Honeypot -> succès silencieux (ne JAMAIS dire au bot qu'il a été détecté).
- `revalidatePath()` à chaque mutation qui affecte une UI rendue côté serveur.
- Log serveur + message utilisateur générique (ne pas leak le stack trace).

