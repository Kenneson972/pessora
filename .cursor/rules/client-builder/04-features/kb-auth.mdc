## 3. Login page — pattern à deux onglets

`app/login/page.tsx` avec tabs. Inspiré du DIAMANTNOIR.

```tsx
"use client";

import { useState } from "react";
import { useSearchParams, useRouter } from "next/navigation";
import { PasswordLoginForm } from "@/components/auth/PasswordLoginForm";
import { TenantMagicLinkFlow } from "@/components/auth/TenantMagicLinkFlow";

type Tab = "proprio" | "tenant";

export default function LoginPage() {
  const params = useSearchParams();
  const router = useRouter();
  const redirect = params.get("redirect") ?? "/espace-client";
  const initialTab = (params.get("tab") as Tab) ?? "tenant";
  const [tab, setTab] = useState<Tab>(initialTab);
  const [error, setError] = useState<string | null>(null);

  return (
    <main className="mx-auto max-w-md px-4 py-16">
      <h1 className="mb-6 font-serif text-3xl">Connexion</h1>

      <div role="tablist" className="mb-8 flex gap-2 border-b">
        <button
          role="tab"
          aria-selected={tab === "tenant"}
          onClick={() => setTab("tenant")}
          className={tab === "tenant" ? "border-b-2 border-primary px-4 py-2" : "px-4 py-2"}
        >
          Client
        </button>
        <button
          role="tab"
          aria-selected={tab === "proprio"}
          onClick={() => setTab("proprio")}
          className={tab === "proprio" ? "border-b-2 border-primary px-4 py-2" : "px-4 py-2"}
        >
          Propriétaire
        </button>
      </div>

      {error && (
        <div role="alert" className="mb-4 rounded bg-red-50 p-3 text-sm text-red-700">
          {error}
        </div>
      )}

      {tab === "tenant" ? (
        <TenantMagicLinkFlow redirect={redirect} onError={setError} />
      ) : (
        <PasswordLoginForm
          redirect={redirect}
          onError={setError}
          onSuccess={() => router.push(redirect)}
        />
      )}
    </main>
  );
}
```

**Erreurs en français.** Jamais afficher `error.message` Supabase brut — mapper vers FR :
- `Invalid login credentials` → "Email ou mot de passe incorrect."
- `Email not confirmed` → "Merci de confirmer votre email avant de vous connecter."
- `For security purposes, you can only request this once every 60 seconds` → "Patientez 60s avant une nouvelle tentative."

