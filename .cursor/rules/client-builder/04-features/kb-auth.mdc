## 4. Magic link OTP (tenant) — `TenantMagicLinkFlow`

Pattern complet, state machine à 3 steps.

```tsx
"use client";

import { useEffect, useState } from "react";
import { useSearchParams, useRouter } from "next/navigation";
import { getSupabaseBrowser } from "@/lib/supabase-browser";

type Step = "email" | "otp" | "profile";

export function TenantMagicLinkFlow({
  redirect,
  onError,
}: {
  redirect: string;
  onError: (msg: string | null) => void;
}) {
  const supabase = getSupabaseBrowser();
  const router = useRouter();
  const params = useSearchParams();

  const [step, setStep] = useState<Step>("email");
  const [email, setEmail] = useState(params.get("email") ?? "");
  const [code, setCode] = useState("");
  const [fullName, setFullName] = useState("");
  const [phone, setPhone] = useState("");
  const [loading, setLoading] = useState(false);
  const [resendIn, setResendIn] = useState(0);

  // Timer "Renvoyer dans Xs"
  useEffect(() => {
    if (resendIn <= 0) return;
    const id = setInterval(() => setResendIn((s) => s - 1), 1000);
    return () => clearInterval(id);
  }, [resendIn]);

  async function sendOtp(e?: React.FormEvent) {
    e?.preventDefault();
    onError(null);
    setLoading(true);
    const { error } = await supabase.auth.signInWithOtp({
      email,
      options: {
        emailRedirectTo: `${window.location.origin}/auth/callback?redirect=${encodeURIComponent(redirect)}`,
        shouldCreateUser: true,
      },
    });
    setLoading(false);
    if (error) return onError("Impossible d'envoyer le code. Réessayez dans quelques secondes.");
    setStep("otp");
    setResendIn(60);
  }

  async function verifyCode(e: React.FormEvent) {
    e.preventDefault();
    onError(null);
    setLoading(true);
    const { data, error } = await supabase.auth.verifyOtp({
      email,
      token: code,
      type: "email",
    });
    setLoading(false);
    if (error) {
      if (error.message.includes("expired")) return onError("Code expiré, renvoyez-en un nouveau.");
      return onError("Code invalide. Vérifiez les 6 chiffres reçus par email.");
    }
    // Nouveau user ? → profile form, sinon redirect direct
    const { data: profile } = await supabase
      .from("profiles")
      .select("full_name")
      .eq("id", data.user!.id)
      .maybeSingle();

    if (!profile?.full_name) {
      setStep("profile");
    } else {
      router.push(redirect);
      router.refresh();
    }
  }

  async function saveProfile(e: React.FormEvent) {
    e.preventDefault();
    onError(null);
    setLoading(true);
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return onError("Session perdue, recommencez.");
    const { error } = await supabase.from("profiles").upsert({
      id: user.id,
      email: user.email,
      full_name: fullName,
      phone,
      role: "tenant",
    });
    setLoading(false);
    if (error) return onError("Erreur lors de l'enregistrement du profil.");
    router.push(redirect);
    router.refresh();
  }

  if (step === "email") {
    return (
      <form onSubmit={sendOtp} className="space-y-4">
        <label className="block">
          <span className="text-sm">Votre email</span>
          <input
            type="email"
            required
            value={email}
            onChange={(e) => setEmail(e.target.value)}
            className="mt-1 w-full rounded border px-3 py-2"
          />
        </label>
        <button type="submit" disabled={loading} className="w-full rounded bg-primary px-4 py-2 text-white disabled:opacity-60">
          {loading ? "Envoi…" : "Recevoir un code"}
        </button>
      </form>
    );
  }

  if (step === "otp") {
    return (
      <form onSubmit={verifyCode} className="space-y-4">
        <p className="text-sm text-neutral-600">Code envoyé à <strong>{email}</strong></p>
        <input
          inputMode="numeric"
          pattern="\d{6}"
          maxLength={6}
          required
          value={code}
          onChange={(e) => setCode(e.target.value.replace(/\D/g, ""))}
          className="w-full rounded border px-3 py-2 text-center text-xl tracking-widest"
          placeholder="123456"
        />
        <button type="submit" disabled={loading || code.length !== 6} className="w-full rounded bg-primary px-4 py-2 text-white disabled:opacity-60">
          {loading ? "Vérification…" : "Valider"}
        </button>
        <button
          type="button"
          disabled={resendIn > 0}
          onClick={() => sendOtp()}
          className="w-full text-sm text-neutral-600 underline disabled:opacity-60"
        >
          {resendIn > 0 ? `Renvoyer le code dans ${resendIn}s` : "Renvoyer le code"}
        </button>
      </form>
    );
  }

  // step === "profile"
  return (
    <form onSubmit={saveProfile} className="space-y-4">
      <h2 className="font-serif text-xl">Finaliser votre profil</h2>
      <input required value={fullName} onChange={(e) => setFullName(e.target.value)} placeholder="Nom complet" className="w-full rounded border px-3 py-2" />
      <input type="tel" value={phone} onChange={(e) => setPhone(e.target.value)} placeholder="Téléphone (optionnel)" className="w-full rounded border px-3 py-2" />
      <button type="submit" disabled={loading} className="w-full rounded bg-primary px-4 py-2 text-white disabled:opacity-60">
        {loading ? "Enregistrement…" : "Continuer"}
      </button>
    </form>
  );
}
```

**Note sur la révocation** : un OTP Supabase n'est utilisable qu'une fois et expire après 1h (config dashboard). Pas de logique de revocation manuelle nécessaire.

