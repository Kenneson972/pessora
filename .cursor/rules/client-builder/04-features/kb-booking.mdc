## 4. Disponibilités

Calcul dispo **exclusivement serveur**. Le front ne reconstruit jamais le calendrier depuis la liste brute des bookings sans passer par une vue serveur — sinon risque de leak.

```ts
// lib/booking/availability.ts
import { createSupabaseServer } from '@/lib/supabase-server';
import { addDays, differenceInDays } from 'date-fns';

export interface AvailabilityCheck {
  available: boolean;
  conflicts: Array<{ start_date: string; end_date: string; source: string }>;
  nights: number;
}

export async function checkAvailability(
  propertyId: string,
  startDate: string,  // 'YYYY-MM-DD'
  endDate: string
): Promise<AvailabilityCheck> {
  const supabase = createSupabaseServer();

  // Buffer checkout : 1 nuit de battement pour ménage (configurable par property)
  const nights = differenceInDays(new Date(endDate), new Date(startDate));

  const { data: conflicts, error } = await supabase
    .from('bookings')
    .select('start_date, end_date, source')
    .eq('property_id', propertyId)
    .in('status', ['pending', 'confirmed'])
    .or(`and(start_date.lt.${endDate},end_date.gt.${startDate})`);

  if (error) throw error;

  const { data: blocks } = await supabase
    .from('availability_blocks')
    .select('start_date, end_date')
    .eq('property_id', propertyId)
    .or(`and(start_date.lt.${endDate},end_date.gt.${startDate})`);

  return {
    available: (conflicts?.length ?? 0) === 0 && (blocks?.length ?? 0) === 0,
    conflicts: [...(conflicts ?? []), ...(blocks ?? []).map(b => ({ ...b, source: 'block' }))],
    nights,
  };
}
```

**Vue SQL pour le calendrier public** (expose uniquement les plages, pas les données guest) :

```sql
create view booking_calendar_slots as
select property_id, start_date, end_date, source
from bookings
where status in ('pending','confirmed')
union all
select property_id, start_date, end_date, 'block' as source
from availability_blocks;

-- RLS : anyone can select (c'est public par design)
grant select on booking_calendar_slots to anon, authenticated;
```

