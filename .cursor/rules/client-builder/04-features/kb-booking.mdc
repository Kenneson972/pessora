## 2. Modèle de données

Les cinq tables du domaine. RLS activée partout.

```sql
-- Bien immobilier / logement
create table properties (
  id uuid primary key default gen_random_uuid(),
  owner_id uuid references auth.users(id) on delete set null,
  slug text unique not null,
  name text not null,
  location text,
  capacity int not null default 2,
  price_per_night numeric(10,2) not null,
  cleaning_fee numeric(10,2) not null default 0,
  min_nights int not null default 1,
  max_nights int not null default 30,
  checkin_time time default '16:00',
  checkout_time time default '11:00',
  timezone text not null default 'Europe/Paris',
  ical_url text,                -- legacy canal unique
  ota_channels jsonb default '[]'::jsonb, -- [{source, ical_url, label}]
  ical_export_token text unique, -- pour URL publique .ics
  created_at timestamptz default now()
);

-- Réservation (directe ou OTA)
create table bookings (
  id uuid primary key default gen_random_uuid(),
  property_id uuid references properties(id) on delete cascade not null,
  start_date date not null,
  end_date date not null,
  guest_count int not null default 1,
  guest_name text,
  guest_email text,
  guest_phone text,
  status text not null default 'pending'
    check (status in ('pending','confirmed','cancelled','refunded','no_show','completed')),
  payment_status text not null default 'unpaid'
    check (payment_status in ('unpaid','paid','refunded','partial')),
  source text not null default 'direct'
    check (source in ('direct','airbnb','booking','expedia','vrbo','trivago')),
  total_price numeric(10,2) not null default 0,
  cleaning_fee numeric(10,2) not null default 0,
  tourist_tax numeric(10,2) not null default 0,
  stripe_session_id text,
  stripe_payment_intent_id text,
  external_id text,              -- UID iCal source externe
  access_token uuid default gen_random_uuid(), -- guest voit via token
  notes text,
  created_at timestamptz default now(),
  constraint booking_dates_valid check (end_date > start_date),
  unique (property_id, external_id)
);

-- Blocage manuel du proprio (entretien, séjour perso)
create table availability_blocks (
  id uuid primary key default gen_random_uuid(),
  property_id uuid references properties(id) on delete cascade not null,
  start_date date not null,
  end_date date not null,
  reason text,
  created_at timestamptz default now()
);

-- Règles de prix (saisonnier, weekend, long séjour)
create table pricing_rules (
  id uuid primary key default gen_random_uuid(),
  property_id uuid references properties(id) on delete cascade not null,
  kind text not null check (kind in ('seasonal','weekend','weekly_discount','min_stay')),
  start_date date,
  end_date date,
  multiplier numeric(4,2),       -- ex: 1.5 pour haute saison
  discount_percent int,          -- ex: 10 pour -10% sur 7+ nuits
  priority int not null default 0
);

-- Flux iCal entrants (audit + last sync)
create table ical_feeds (
  id uuid primary key default gen_random_uuid(),
  property_id uuid references properties(id) on delete cascade not null,
  source text not null,
  ical_url text not null,
  last_sync_at timestamptz,
  last_sync_status text,
  last_error text,
  inserted_count int default 0
);

-- Anti double-booking (exclusion sur ranges)
create extension if not exists btree_gist;
alter table bookings add column period daterange
  generated always as (daterange(start_date, end_date, '[)')) stored;
alter table bookings
  add constraint bookings_no_overlap
  exclude using gist (property_id with =, period with &&)
  where (status in ('pending','confirmed'));
```

**Clé** : la contrainte `exclude` empêche en base deux bookings actifs qui se chevauchent. C'est la dernière ligne de défense — on valide aussi côté app pour un message propre.

