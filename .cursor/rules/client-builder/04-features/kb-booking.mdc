## 5. Sync iCal (Airbnb / Booking / Vrbo / Expedia)

**Import** via `node-ical`. **Export** via un endpoint `.ics` signé par token. Tous les OTAs majeurs parlent iCal RFC 5545.

### Import — pattern multi-sources

```ts
// lib/ical-sync.ts
import ical from 'node-ical';
import type { SupabaseClient } from '@supabase/supabase-js';

export type OTASource = 'airbnb' | 'booking' | 'expedia' | 'vrbo' | 'trivago';

export const detectOTASource = (url: string): OTASource | 'direct' => {
  if (url.includes('airbnb.')) return 'airbnb';
  if (url.includes('booking.com')) return 'booking';
  if (url.includes('expedia.') || url.includes('homeaway.')) return 'expedia';
  if (url.includes('vrbo.com')) return 'vrbo';
  return 'direct';
};

export async function syncOTAChannel(
  channel: { source: OTASource; ical_url: string },
  propertyId: string,
  supabase: SupabaseClient
) {
  const events = await ical.async.fromURL(channel.ical_url);

  const rows = Object.values(events)
    .filter(e => e.type === 'VEVENT')
    .map(e => ({
      property_id: propertyId,
      start_date: toDateOnly(e.start as Date),
      end_date: toDateOnly(e.end as Date),
      status: 'confirmed' as const,
      source: channel.source,
      guest_name: e.summary || `Réservation ${channel.source}`,
      total_price: 0,
      // Namespacer par source pour éviter collision d'UIDs entre OTAs
      external_id: `${channel.source}_${e.uid}`,
    }));

  if (!rows.length) return { inserted: 0, deleted: 0 };

  const externalIds = rows.map(r => r.external_id);

  // 1. Supprimer les bookings de cette source qui ne sont plus dans le flux
  const { count: deleted } = await supabase
    .from('bookings')
    .delete({ count: 'exact' })
    .eq('property_id', propertyId)
    .eq('source', channel.source)
    .not('external_id', 'in', `(${externalIds.map(id => `'${id}'`).join(',')})`);

  // 2. Upsert les actuels (idempotent grâce au unique (property_id, external_id))
  const { error } = await supabase
    .from('bookings')
    .upsert(rows, { onConflict: 'property_id,external_id' });

  if (error) throw error;
  return { inserted: rows.length, deleted: deleted ?? 0 };
}
```

