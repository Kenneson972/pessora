## 8. Server Actions et API Routes

### Quote — Server Action

```ts
// app/actions/booking.ts
'use server';
import { z } from 'zod';
import { createSupabaseServer } from '@/lib/supabase-server';
import { calculatePrice } from '@/lib/price-engine';
import { checkAvailability } from '@/lib/booking/availability';

const QuoteInput = z.object({
  propertyId: z.string().uuid(),
  startDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/),
  endDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/),
  guestCount: z.number().int().positive().max(30),
});

export async function createBookingQuote(raw: unknown) {
  const input = QuoteInput.parse(raw);

  const supabase = createSupabaseServer();
  const { data: property, error } = await supabase
    .from('properties')
    .select('*, pricing_rules(*)')
    .eq('id', input.propertyId)
    .single();

  if (error || !property) return { error: 'Property not found' };
  if (input.guestCount > property.capacity) {
    return { error: `Capacité max ${property.capacity}` };
  }

  const availability = await checkAvailability(
    input.propertyId, input.startDate, input.endDate
  );
  if (!availability.available) return { error: 'Dates indisponibles' };

  const price = calculatePrice({
    startDate: new Date(input.startDate),
    endDate: new Date(input.endDate),
    basePrice: property.price_per_night,
    cleaningFee: property.cleaning_fee,
    rules: property.pricing_rules,
  });

  return { quote: { ...price, propertyId: input.propertyId, ...input } };
}
```

### Confirm + Stripe Session — Route Handler

```ts
// app/api/booking/route.ts
import { NextResponse } from 'next/server';
import Stripe from 'stripe';
import { supabaseAdmin } from '@/lib/supabase';
import { calculatePrice } from '@/lib/price-engine';
import { checkAvailability } from '@/lib/booking/availability';

export const runtime = 'nodejs';
const stripe = new Stripe(process.env.STRIPE_SECRET_KEY!, { apiVersion: '2023-10-16' });

export async function POST(req: Request) {
  const { propertyId, startDate, endDate, guestCount, guestName, guestEmail } = await req.json();

  // 1. RE-VALIDER côté serveur (jamais trust le client)
  const supabase = supabaseAdmin();
  const { data: property } = await supabase.from('properties')
    .select('*, pricing_rules(*)').eq('id', propertyId).single();
  if (!property) return NextResponse.json({ error: 'Property not found' }, { status: 404 });

  const availability = await checkAvailability(propertyId, startDate, endDate);
  if (!availability.available) {
    return NextResponse.json({ error: 'Dates indisponibles' }, { status: 409 });
  }

  const price = calculatePrice({
    startDate: new Date(startDate), endDate: new Date(endDate),
    basePrice: property.price_per_night, cleaningFee: property.cleaning_fee,
    rules: property.pricing_rules,
  });

  // 2. Insert booking pending (la contrainte exclude empêche tout overlap)
  const { data: booking, error: insertError } = await supabase
    .from('bookings')
    .insert({
      property_id: propertyId, start_date: startDate, end_date: endDate,
      guest_count: guestCount, guest_name: guestName, guest_email: guestEmail,
      status: 'pending', payment_status: 'unpaid', source: 'direct',
      total_price: price.total, cleaning_fee: price.cleaningFee,
    })
    .select().single();
  if (insertError) {
    // Code 23P01 = exclusion violation (overlap)
    if (insertError.code === '23P01') {
      return NextResponse.json({ error: 'Dates réservées entre-temps' }, { status: 409 });
    }
    throw insertError;
  }

  // 3. Stripe Checkout Session
  const session = await stripe.checkout.sessions.create({
    mode: 'payment',
    customer_email: guestEmail,
    success_url: `${process.env.NEXT_PUBLIC_BASE_URL}/booking/success?session_id={CHECKOUT_SESSION_ID}`,
    cancel_url: `${process.env.NEXT_PUBLIC_BASE_URL}/properties/${property.slug}?cancelled=1`,
    metadata: { bookingId: booking.id, propertyId },
    line_items: [{
      quantity: 1,
      price_data: {
        currency: 'eur',
        unit_amount: Math.round(price.total * 100),
        product_data: {
          name: `Séjour — ${property.name}`,
          description: `${startDate} → ${endDate} (${price.nights} nuits)`,
        },
      },
    }],
    // Expire le pending si pas payé
    expires_at: Math.floor(Date.now() / 1000) + 30 * 60,
  });

  await supabase.from('bookings')
    .update({ stripe_session_id: session.id }).eq('id', booking.id);

  return NextResponse.json({ url: session.url, bookingId: booking.id });
}
```

### Webhook Stripe — idempotent

```ts
// app/api/webhooks/stripe/route.ts
export const runtime = 'nodejs';

export async function POST(req: Request) {
  const body = await req.text();
  const sig = req.headers.get('stripe-signature');
  if (!sig) return NextResponse.json({ error: 'Missing signature' }, { status: 400 });

  let event: Stripe.Event;
  try {
    event = stripe.webhooks.constructEvent(body, sig, process.env.STRIPE_WEBHOOK_SECRET!);
  } catch (err) {
    return NextResponse.json({ error: 'Invalid signature' }, { status: 400 });
  }

  if (event.type === 'checkout.session.completed') {
    const session = event.data.object as Stripe.Checkout.Session;
    const bookingId = session.metadata?.bookingId;
    if (!bookingId) return NextResponse.json({ received: true });

    const supabase = supabaseAdmin();

    // Idempotence : update conditional — si déjà confirmed, no-op
    const { data: updated } = await supabase
      .from('bookings')
      .update({
        status: 'confirmed',
        payment_status: 'paid',
        stripe_payment_intent_id: session.payment_intent as string,
      })
      .eq('id', bookingId)
      .eq('status', 'pending')  // ← idempotent
      .select().single();

    if (updated) {
      // Envoi email — fire and forget, ne pas bloquer le webhook
      fetch(`${baseUrl}/api/notifications/booking-confirmation`, {
        method: 'POST',
        body: JSON.stringify({ bookingId }),
      }).catch(e => console.error('Email failed:', e));
    }
  }

  if (event.type === 'checkout.session.expired') {
    const session = event.data.object as Stripe.Checkout.Session;
    await supabaseAdmin().from('bookings')
      .update({ status: 'cancelled' })
      .eq('stripe_session_id', session.id).eq('status', 'pending');
  }

  return NextResponse.json({ received: true });
}
```

