## 10. Pattern ErrorState composant générique

Pour les erreurs affichées inline (section qui a raté son fetch, mais sans crash le segment complet) :

```tsx
// components/ui/ErrorState.tsx
import type { ReactNode } from "react";

type Props = {
  title?: string;
  description?: string;
  onRetry?: () => void;
  icon?: ReactNode;
};

export function ErrorState({
  title = "Une erreur s'est produite",
  description = "Impossible de charger ce contenu. Réessayez dans un instant.",
  onRetry,
  icon,
}: Props) {
  return (
    <div role="alert" className="flex flex-col items-center rounded-xl border border-red-200 bg-red-50 p-8 text-center">
      {icon && <div className="mb-3 text-red-500">{icon}</div>}
      <h3 className="font-semibold text-red-900">{title}</h3>
      <p className="mt-2 max-w-md text-sm text-red-800">{description}</p>
      {onRetry && (
        <button
          type="button"
          onClick={onRetry}
          className="mt-4 rounded-md border border-red-300 bg-white px-4 py-2 text-sm text-red-900 hover:bg-red-100"
        >
          Réessayer
        </button>
      )}
    </div>
  );
}
```

