## 3. error.tsx : "use client" obligatoire

Next 15 injecte `error` (objet Error) et `reset` (callback pour retenter le rendu).

```tsx
// app/services/[slug]/error.tsx
"use client";

import { useEffect } from "react";

export default function ServiceError({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  useEffect(() => {
    // Log côté client (Sentry / PostHog / console en dev)
    console.error("[Service detail error]", error);
    // Sentry.captureException(error, { tags: { route: "services/[slug]" } });
  }, [error]);

  return (
    <div className="mx-auto max-w-xl px-4 py-24 text-center">
      <h2 className="text-2xl font-semibold">Impossible de charger ce service</h2>
      <p className="mt-3 text-gray-600">
        Une erreur est survenue. Vous pouvez réessayer ou revenir plus tard.
      </p>
      {process.env.NODE_ENV === "development" && (
        <pre className="mt-4 overflow-auto rounded bg-gray-100 p-3 text-left text-xs">
          {error.message}
          {error.digest && `\ndigest: ${error.digest}`}
        </pre>
      )}
      <div className="mt-6 flex justify-center gap-3">
        <button
          type="button"
          onClick={reset}
          className="rounded-md bg-primary px-4 py-2 text-white"
        >
          Réessayer
        </button>
        <a href="/services" className="rounded-md border px-4 py-2">
          Retour aux services
        </a>
      </div>
    </div>
  );
}
```

Règles :
- **`"use client"` obligatoire** — sinon build error.
- `error.digest` en prod = ID unique côté serveur (cherchable dans les logs Vercel).
- En prod, ne pas afficher `error.message` à l'utilisateur -> leak d'implémentation.
- Le bouton "Réessayer" appelle `reset()` — Next re-render le segment. N'essaye pas de `window.location.reload()`.
- UI cohérente avec le reste du site (typographie, couleurs, tokens design).

### global-error.tsx

Pour les erreurs qui cassent le `RootLayout` lui-même. Doit rendre `<html>` et `<body>` (le layout n'est pas disponible).

```tsx
// app/global-error.tsx
"use client";

export default function GlobalError({
  error,
  reset,
}: {
  error: Error & { digest?: string };
  reset: () => void;
}) {
  return (
    <html lang="fr">
      <body>
        <div style={{ padding: "4rem 1rem", textAlign: "center", fontFamily: "system-ui" }}>
          <h1>Erreur critique</h1>
          <p>Le site rencontre un problème technique. Merci de réessayer dans quelques instants.</p>
          <button type="button" onClick={reset} style={{ marginTop: "1rem" }}>
            Réessayer
          </button>
        </div>
      </body>
    </html>
  );
}
```

Un seul `global-error.tsx` par app, à la racine.

