## 7. JSON-LD (Structured Data)

**Règle** : JSON-LD inséré via un `<script>` dans le JSX d'un **Server Component**, jamais dans `metadata`.

### Helper `lib/seo/schemas.ts`

```ts
// lib/seo/schemas.ts
import type {
  LocalBusiness,
  Product,
  Service,
  FAQPage,
  BreadcrumbList,
  Article,
  LodgingBusiness,
  Restaurant,
  WithContext,
} from 'schema-dts'

const SITE_URL =
  process.env.NEXT_PUBLIC_SITE_URL ?? 'https://karibloom.com'

export function buildLocalBusinessSchema(): WithContext<LocalBusiness> {
  return {
    '@context': 'https://schema.org',
    '@type': 'LocalBusiness',
    name: 'Karibloom',
    url: SITE_URL,
    telephone: '+596-XXX-XXX-XXX',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Fort-de-France',
      addressRegion: 'Martinique',
      addressCountry: 'FR',
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '09:00',
        closes: '18:00',
      },
    ],
  }
}

export function buildProductSchema(p: {
  name: string
  description: string
  image: string
  slug: string
  price: number
  currency: string
  availability?: 'InStock' | 'OutOfStock' | 'PreOrder'
}): WithContext<Product> {
  return {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: p.name,
    description: p.description,
    image: p.image,
    url: `${SITE_URL}/produits/${p.slug}`,
    offers: {
      '@type': 'Offer',
      price: p.price.toString(),
      priceCurrency: p.currency,
      availability: `https://schema.org/${p.availability ?? 'InStock'}`,
      url: `${SITE_URL}/produits/${p.slug}`,
    },
  }
}

export function buildBreadcrumbSchema(
  items: { name: string; url: string }[]
): WithContext<BreadcrumbList> {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: `${SITE_URL}${item.url}`,
    })),
  }
}

export function buildFAQSchema(
  qa: { question: string; answer: string }[]
): WithContext<FAQPage> {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: qa.map((x) => ({
      '@type': 'Question',
      name: x.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: x.answer,
      },
    })),
  }
}

export function buildServiceSchema(s: {
  name: string
  description: string
  slug: string
  areaServed?: string
}): WithContext<Service> {
  return {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: s.name,
    description: s.description,
    url: `${SITE_URL}/services/${s.slug}`,
    provider: {
      '@type': 'LocalBusiness',
      name: 'Karibloom',
    },
    areaServed: s.areaServed ?? 'Martinique',
  }
}

export function buildLodgingSchema(p: {
  name: string
  description: string
  slug: string
  image: string
  city: string
}): WithContext<LodgingBusiness> {
  return {
    '@context': 'https://schema.org',
    '@type': 'LodgingBusiness',
    name: p.name,
    description: p.description,
    image: p.image,
    url: `${SITE_URL}/proprietes/${p.slug}`,
    address: {
      '@type': 'PostalAddress',
      addressLocality: p.city,
      addressCountry: 'FR',
    },
  }
}

export function buildRestaurantSchema(r: {
  name: string
  servesCuisine: string[]
  priceRange: string
}): WithContext<Restaurant> {
  return {
    '@context': 'https://schema.org',
    '@type': 'Restaurant',
    name: r.name,
    servesCuisine: r.servesCuisine,
    priceRange: r.priceRange,
  }
}

export function buildArticleSchema(a: {
  headline: string
  image: string
  datePublished: string
  dateModified: string
  authorName: string
  slug: string
}): WithContext<Article> {
  return {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: a.headline,
    image: a.image,
    datePublished: a.datePublished,
    dateModified: a.dateModified,
    author: { '@type': 'Person', name: a.authorName },
    url: `${SITE_URL}/blog/${a.slug}`,
  }
}
```

### Composant `JsonLd`

```tsx
// components/seo/JsonLd.tsx
export function JsonLd({ data }: { data: object }) {
  return (
    <script
      type="application/ld+json"
      dangerouslySetInnerHTML={{ __html: JSON.stringify(data) }}
    />
  )
}
```

### Usage dans une page

```tsx
// app/produits/[slug]/page.tsx
import { JsonLd } from '@/components/seo/JsonLd'
import {
  buildProductSchema,
  buildBreadcrumbSchema,
} from '@/lib/seo/schemas'

export default async function ProductPage({ params }: Props) {
  const { slug } = await params
  const product = await getProductBySlug(slug)

  return (
    <>
      <JsonLd
        data={buildProductSchema({
          name: product.name,
          description: product.description,
          image: product.coverUrl,
          slug: product.slug,
          price: product.price,
          currency: 'EUR',
        })}
      />
      <JsonLd
        data={buildBreadcrumbSchema([
          { name: 'Accueil', url: '/' },
          { name: 'Produits', url: '/produits' },
          { name: product.name, url: `/produits/${product.slug}` },
        ])}
      />
      <article>...</article>
    </>
  )
}
```

### Schémas pertinents par projet Karibloom

| Projet | Schémas à activer |
|---|---|
| Site agence Karibloom | `LocalBusiness`, `Service`, `FAQPage`, `BreadcrumbList` |
| DIAMANTNOIR / PESSORA (e-commerce) | `Product`, `BreadcrumbList`, `FAQPage` |
| Conciergerie (propriétés) | `LodgingBusiness`, `BreadcrumbList` |
| DALCIELO (restaurant) | `Restaurant`, `LocalBusiness`, `FAQPage` |
| Blog / articles | `Article`, `BreadcrumbList` |

