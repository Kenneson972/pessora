## 8. Composant wrapper `OptimizedImage`

Impose les bonnes props par convention.

```tsx
// components/ui/OptimizedImage.tsx
import Image, { type ImageProps } from 'next/image'

type Props = Omit<ImageProps, 'placeholder'> & {
  blurDataURL?: string
}

export function OptimizedImage({
  alt,
  sizes = '100vw',
  blurDataURL,
  ...props
}: Props) {
  if (alt === undefined) {
    throw new Error('OptimizedImage: alt est obligatoire')
  }

  return (
    <Image
      {...props}
      alt={alt}
      sizes={sizes}
      placeholder={blurDataURL ? 'blur' : 'empty'}
      blurDataURL={blurDataURL}
    />
  )
}
```

