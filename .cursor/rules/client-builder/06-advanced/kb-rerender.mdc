## 5. useMediaQuery — Booléen, pas la valeur continue

Pour le responsive, s'abonner à un booléen dérivé plutôt qu'à la largeur brute.
`useWindowWidth()` déclenche un render à chaque pixel. `useMediaQuery()` seulement au franchissement.

**Incorrect (re-render à chaque px de resize) :**

```tsx
function Header() {
  const width = useWindowWidth()    // re-render à 1280, 1279, 1278...
  const isMobile = width < 768

  return <nav className={isMobile ? 'mobile-nav' : 'desktop-nav'} />
}
```

**Correct (re-render uniquement au changement de breakpoint) :**

```tsx
// Hook léger à garder dans src/hooks/useMediaQuery.ts
function useMediaQuery(query: string): boolean {
  const [matches, setMatches] = useState(
    () => typeof window !== 'undefined' && window.matchMedia(query).matches
  )
  useEffect(() => {
    const mql = window.matchMedia(query)
    const handler = (e: MediaQueryListEvent) => setMatches(e.matches)
    mql.addEventListener('change', handler)
    return () => mql.removeEventListener('change', handler)
  }, [query])
  return matches
}

// Usage
function Header() {
  const isMobile = useMediaQuery('(max-width: 767px)')  // re-render : 2 fois max
  return <nav className={isMobile ? 'mobile-nav' : 'desktop-nav'} />
}
```

