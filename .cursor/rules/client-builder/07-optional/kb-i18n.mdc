## 4. Language Switcher

```jsx
// components/common/LanguageSwitcher.jsx
import { useTranslation } from 'react-i18next';

const LANGUAGES = [
  { code: 'fr', label: 'FR', flag: '🇫🇷' },
  { code: 'en', label: 'EN', flag: '🇬🇧' },
];

const LanguageSwitcher = () => {
  const { i18n } = useTranslation();
  const current = i18n.language?.split('-')[0] || 'fr';

  return (
    <div className="lang-switcher" role="navigation" aria-label="Changer de langue">
      {LANGUAGES.map(lang => (
        <button
          key={lang.code}
          onClick={() => i18n.changeLanguage(lang.code)}
          className={`lang-btn ${current === lang.code ? 'active' : ''}`}
          aria-current={current === lang.code ? 'true' : undefined}
          aria-label={`Langue : ${lang.label}`}
        >
          {lang.flag} {lang.label}
        </button>
      ))}
    </div>
  );
};
```

```css
.lang-switcher { display: flex; gap: 4px; }
.lang-btn {
  background: none; border: 1.5px solid var(--border-color);
  border-radius: 6px; padding: 4px 10px; font-size: 0.85rem;
  cursor: pointer; color: var(--text-secondary);
  transition: all 0.15s ease;
}
.lang-btn.active {
  border-color: var(--color-primary);
  color: var(--color-primary);
  font-weight: 600;
}
```

