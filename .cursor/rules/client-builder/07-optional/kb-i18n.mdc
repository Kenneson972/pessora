## 5. SEO multilingue — hreflang

```jsx
// components/common/SEOHead.jsx — ajouter les balises hreflang
import { useTranslation } from 'react-i18next';
import { Helmet } from 'react-helmet-async';

const SEOHead = ({ title, description, url, schema, noindex = false }) => {
  const { i18n } = useTranslation();
  const lang = i18n.language?.split('-')[0] || 'fr';
  const BASE_URL = 'https://nomclient.fr'; // à remplacer

  return (
    <Helmet>
      <html lang={lang} />
      <title>{title}</title>
      <meta name="description" content={description} />
      {noindex && <meta name="robots" content="noindex, nofollow" />}

      {/* hreflang — indiquer les versions alternatives aux moteurs de recherche */}
      <link rel="alternate" hrefLang="fr" href={`${BASE_URL}/fr${url}`} />
      <link rel="alternate" hrefLang="en" href={`${BASE_URL}/en${url}`} />
      <link rel="alternate" hrefLang="x-default" href={`${BASE_URL}${url}`} />

      {/* Open Graph avec langue */}
      <meta property="og:locale" content={lang === 'fr' ? 'fr_FR' : 'en_US'} />
      <meta property="og:locale:alternate" content={lang === 'fr' ? 'en_US' : 'fr_FR'} />

      {schema && <script type="application/ld+json">{JSON.stringify(schema)}</script>}
    </Helmet>
  );
};
```

