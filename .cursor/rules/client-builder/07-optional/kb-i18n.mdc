## 3. Usage dans les composants

```jsx
// Hooks principaux
import { useTranslation } from 'react-i18next';

const Header = () => {
  const { t, i18n } = useTranslation('common');

  return (
    <nav>
      <a href="/">{t('nav.home')}</a>
      <a href="/services">{t('nav.services')}</a>
      <LanguageSwitcher />
    </nav>
  );
};

// Interpolation avec variables
// JSON: "welcome": "Bienvenue, {{name}} !"
t('welcome', { name: 'Kenneson' }) // → "Bienvenue, Kenneson !"

// Pluralisation
// JSON: "item_one": "{{count}} article", "item_other": "{{count}} articles"
t('item', { count: 5 }) // → "5 articles"

// Trans pour HTML dans les traductions
import { Trans } from 'react-i18next';
// JSON: "cgu": "J'accepte les <1>conditions d'utilisation</1>"
<Trans i18nKey="cgu">
  J'accepte les <a href="/cgu">conditions d'utilisation</a>
</Trans>
```

