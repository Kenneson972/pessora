## 3. Service Worker avec Workbox (CRA/CRACO)

```bash
npm install workbox-webpack-plugin workbox-window
```

```js
// craco.config.js — ajouter le plugin Workbox
const { InjectManifest } = require('workbox-webpack-plugin');
const path = require('path');

module.exports = {
  webpack: {
    plugins: {
      add: [
        new InjectManifest({
          swSrc: './src/service-worker.js',
          swDest: 'service-worker.js',
          maximumFileSizeToCacheInBytes: 5 * 1024 * 1024, // 5MB max
        }),
      ],
    },
  },
};
```

```js
// src/service-worker.js — stratégies de cache Workbox
import { precacheAndRoute, cleanupOutdatedCaches } from 'workbox-precaching';
import { registerRoute } from 'workbox-routing';
import { CacheFirst, NetworkFirst, StaleWhileRevalidate } from 'workbox-strategies';
import { ExpirationPlugin } from 'workbox-expiration';
import { CacheableResponsePlugin } from 'workbox-cacheable-response';

// Nettoyage des anciens caches
cleanupOutdatedCaches();

// Précache des assets build (JS, CSS, HTML)
precacheAndRoute(self.__WB_MANIFEST);

// ════════════════════════════════════════
// STRATÉGIE 1 : Images → Cache First (30 jours)
// Les images changent rarement, prioriser la vitesse
// ════════════════════════════════════════
registerRoute(
  ({ request }) => request.destination === 'image',
  new CacheFirst({
    cacheName: 'kb-images-v1',
    plugins: [
      new CacheableResponsePlugin({ statuses: [0, 200] }),
      new ExpirationPlugin({ maxEntries: 60, maxAgeSeconds: 30 * 24 * 60 * 60 }),
    ],
  })
);

// ════════════════════════════════════════
// STRATÉGIE 2 : Fonts → Cache First (1 an)
// ════════════════════════════════════════
registerRoute(
  ({ url }) => url.origin === 'https://fonts.gstatic.com',
  new CacheFirst({
    cacheName: 'kb-fonts-v1',
    plugins: [
      new CacheableResponsePlugin({ statuses: [0, 200] }),
      new ExpirationPlugin({ maxAgeSeconds: 365 * 24 * 60 * 60 }),
    ],
  })
);

// ════════════════════════════════════════
// STRATÉGIE 3 : API/données → Network First (fallback cache)
// Contenu dynamique : on tente le réseau d'abord
// ════════════════════════════════════════
registerRoute(
  ({ url }) => url.pathname.startsWith('/api/') || url.pathname.includes('.php'),
  new NetworkFirst({
    cacheName: 'kb-api-v1',
    plugins: [
      new ExpirationPlugin({ maxEntries: 30, maxAgeSeconds: 24 * 60 * 60 }),
    ],
  })
);

// ════════════════════════════════════════
// STRATÉGIE 4 : Pages HTML → Stale While Revalidate
// ════════════════════════════════════════
registerRoute(
  ({ request }) => request.mode === 'navigate',
  new NetworkFirst({
    cacheName: 'kb-pages-v1',
    plugins: [
      new ExpirationPlugin({ maxEntries: 10, maxAgeSeconds: 7 * 24 * 60 * 60 }),
    ],
    networkTimeoutSeconds: 3, // fallback cache si pas de réponse en 3s
  })
);
```

