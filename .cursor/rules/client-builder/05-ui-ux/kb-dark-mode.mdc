## 4. Utilisation dans l'App

```jsx
// App.jsx — initialiser le thème au démarrage
import { useDarkMode } from './hooks/useDarkMode';
import ThemeToggle from './components/ui/ThemeToggle';

function App() {
  useDarkMode(); // initialise data-theme sur <html> au mount

  return (
    <div className="app">
      <Header>
        <ThemeToggle />
      </Header>
      {/* ... */}
    </div>
  );
}
```

