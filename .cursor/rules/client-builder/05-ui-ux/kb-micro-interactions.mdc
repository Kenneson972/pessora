## 2. Button States (loading, success, error)

Chaque bouton soumis doit avoir 4 états : idle → loading → success/error → idle.

```jsx
// hooks/useButtonState.js
export const useButtonState = () => {
  const [state, setState] = useState('idle'); // idle | loading | success | error

  const trigger = async (asyncFn) => {
    setState('loading');
    try {
      await asyncFn();
      setState('success');
      setTimeout(() => setState('idle'), 2000);
    } catch {
      setState('error');
      setTimeout(() => setState('idle'), 2500);
    }
  };

  return { state, trigger };
};

// Composant bouton complet
const ActionButton = ({ onClick, label, className = 'btn-primary' }) => {
  const { state, trigger } = useButtonState();

  const content = {
    idle:    label,
    loading: <><span className="btn-spinner" /> Envoi...</>,
    success: <>✓ Envoyé !</>,
    error:   <>✗ Erreur, réessaie</>,
  };

  return (
    <button
      className={`${className} btn-state-${state}`}
      onClick={() => trigger(onClick)}
      disabled={state === 'loading'}
      aria-live="polite"
    >
      {content[state]}
    </button>
  );
};
```

```css
/* Styles états bouton */
.btn-state-loading { opacity: 0.8; cursor: wait; }
.btn-state-success { background: var(--color-success, #22c55e) !important; }
.btn-state-error   { background: var(--color-error, #ef4444) !important; animation: btn-shake 0.4s ease; }

@keyframes btn-shake {
  0%, 100% { transform: translateX(0); }
  20%, 60%  { transform: translateX(-4px); }
  40%, 80%  { transform: translateX(4px); }
}

.btn-spinner {
  display: inline-block;
  width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  vertical-align: middle;
  margin-right: 6px;
}
@keyframes spin { to { transform: rotate(360deg); } }
```

