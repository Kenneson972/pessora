## 3. Hover 3D Tilt (cards premium)

Effet de perspective 3D au survol des cards — augmente énormément la perception de qualité.

```jsx
// hooks/useTilt.js
export const useTilt = (maxTilt = 12) => {
  const ref = useRef(null);

  const handleMove = useCallback((e) => {
    const card = ref.current;
    if (!card) return;
    const { left, top, width, height } = card.getBoundingClientRect();
    const x = (e.clientX - left) / width  - 0.5;  // -0.5 → 0.5
    const y = (e.clientY - top)  / height - 0.5;
    card.style.transform = `perspective(800px) rotateY(${x * maxTilt}deg) rotateX(${-y * maxTilt}deg) scale(1.02)`;
  }, [maxTilt]);

  const handleLeave = useCallback(() => {
    if (ref.current) ref.current.style.transform = '';
  }, []);

  return { ref, onMouseMove: handleMove, onMouseLeave: handleLeave };
};

// Usage sur une card
const PremiumCard = ({ service }) => {
  const tilt = useTilt(8);
  return (
    <div className="glass-card tilt-card" {...tilt}>
      {/* contenu */}
    </div>
  );
};
```

```css
.tilt-card {
  transition: transform 0.1s ease;
  transform-style: preserve-3d;
  will-change: transform;
}
/* Désactiver sur mobile (touch) */
@media (hover: none) {
  .tilt-card { transition: none; }
}
```

